<?xml version="1.0" encoding="UTF-8"?>
<!-- 人形为多仓库；仅在 manifest 中合并为一个文件。共用 group「humanoid」：repo sync -g core,humanoid 一次拉齐全套人形应用仓库。 -->
<manifest>
    <project name="humanoid_common" path="application/native/humanoid_common" groups="default,humanoid,humanoid_common" />
    <project name="humanoid_unitree_g1" path="application/native/humanoid_unitree_g1" groups="default,humanoid,app_humanoid_unitree_g1" />
    <project name="humanoid_unitree_go1" path="application/native/humanoid_unitree_go1" groups="default,humanoid,app_humanoid_unitree_go1" />
    <project name="humanoid_unitree_h1_2" path="application/native/humanoid_unitree_h1_2" groups="default,humanoid,app_humanoid_unitree_h1_2" />
    <project name="humanoid_unitree_r1" path="application/native/humanoid_unitree_r1" groups="default,humanoid,app_humanoid_unitree_r1" />
    <project name="humanoid_qinglong" path="application/native/humanoid_qinglong" groups="default,humanoid,app_humanoid_qinglong" />
    <project name="humanoid_tiangong" path="application/native/humanoid_tiangong" groups="default,humanoid,app_humanoid_tiangong" />
</manifest>
