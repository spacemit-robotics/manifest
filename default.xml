    <include name="component/model_zoo.xml" />
    <include name="component/agent_tools.xml" />
    <include name="component/peripherals.xml" />
    <include name="component/control.xml" />

    <include name="application/omni_agent.xml" />
    <include name="application/humanoid.xml" />
    <include name="application/reachy_mini.xml" />
    <include name="application/rivision.xml" />
    <include name="application/lerobot_app.xml" />
    <include name="application/linksee.xml" />

    <include name="ros2/control.xml" />
    <include name="ros2/perception.xml" />
    <include name="ros2/planning.xml" />
    <include name="ros2/slam.xml" />
    <include name="ros2/tools.xml" />
